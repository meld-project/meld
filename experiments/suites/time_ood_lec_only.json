  "runs": [
    {
      "name": "lec_time_ood_adaptive",
      "runner": "lec",
      "notes": "Adaptive per-layer selection with drift-aware score.",
      "params": {
        "model_dir": "$MELD_QWEN_MODEL_DIR",
        "split_mode": "time_ood",
        "malicious_manifest_path": "$MELD_TIMEOOD_MAL_MANIFEST",
        "benign_manifest_path": "$MELD_TIMEOOD_BEN_MANIFEST",
        "mal_dir": "$MELD_TIMEOOD_MAL_MD_DIR",
        "benign_dir": "$MELD_TIMEOOD_BEN_MD_DIR",
        "benign_split_strategy": "random",
        "train_end_date": "2025-04-23 08:08:46",
        "val_end_date": "2025-06-14 11:39:39",
        "clf": "logreg",
        "max_tokens": 1024,
        "stride": 256,
        "target_fpr": 0.01,
        "lambda_penalty": 0.1,
        "selection_strategy": "drift",
        "layer_pooling": "single",
        "seeds": [40, 41, 42],
        "progress": true,
        "cache_dir": "../results/time_ood_one_shot/cache/qwen3_full",
